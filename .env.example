# JARVIS 3.0 - Environment Configuration Template
# ⚠️  SECURITY WARNING: Never commit .env files with real values!
#
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values
# 3. Never share .env files publicly

# ==========================================
# 🔑 API KEYS & SECRETS (REQUIRED)
# ==========================================

# Google Gemini API Key
# Get it FREE from: https://makersuite.google.com/app/apikey
# ⚠️  Keep this secret! Never commit real API keys!
GEMINI_API_KEY=your_api_key_here

# ==========================================
# 🖥️  SERVER CONFIGURATION
# ==========================================

# Flask Server Settings
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ==========================================
# 🤖 AI MODEL CONFIGURATION
# ==========================================

# Gemini Model Selection
GEMINI_MODEL=gemini-2.0-flash-exp

# ==========================================
# 🌐 CORS & SECURITY
# ==========================================

# Allowed Origins (comma-separated)
# Add your production domain when deploying
CORS_ORIGINS=http://localhost:5173,http://localhost:5000

# ==========================================
# 🔧 ADVANCED SETTINGS (Optional)
# ==========================================

# Request Timeouts (seconds)
REQUEST_TIMEOUT=30

# Logging Level
LOG_LEVEL=INFO

# ==========================================
# 🚀 PRODUCTION SETTINGS (When Deploying)
# ==========================================
# Uncomment and modify for production:
# FLASK_ENV=production
# FLASK_DEBUG=False
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ==========================================
# ⚠️  SECURITY REMINDERS
# ==========================================
# - Never commit .env files
# - Rotate API keys regularly
# - Use different keys for dev/prod
# - Monitor API usage for security
# - Keep python-dotenv updated
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Flask Production
# FLASK_ENV=production
# FLASK_DEBUG=False
```

## CORS Configuration

```
# Allowed origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:5173,http://localhost:5000,http://127.0.0.1:5000
```

## Frontend Configuration

```
# React/Vite
VITE_API_URL=http://localhost:5000
VITE_API_TIMEOUT=30000
```

## Optional: Advanced Settings

```
# Gemini Parameters
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048

# Request Settings
REQUEST_TIMEOUT=30
MAX_MESSAGE_LENGTH=5000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log

# Caching (Future)
# CACHE_TYPE=redis
# REDIS_URL=redis://localhost:6379/0
```

